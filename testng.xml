<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="AutomationExerciseSuite" verbose="1">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="E2E Tests">
        <classes>
            <class name="com.automationexercise.tests.E2ETests"/>
        </classes>
    </test>

    <test name="Valid (Positive) Tests">
        <classes>
            <class name="com.automationexercise.tests.ValidTests"/>
        </classes>
    </test>

    <test name="Invalid (Negative) Tests">
        <classes>
            <class name="com.automationexercise.tests.InvalidTests"/>
        </classes>
    </test>

</suite>
